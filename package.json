{
	"name": "reccado",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.1.1",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"generate-routes": "tsr generate",
		"build": "vite build",
		"preview": "pnpm run build && vite preview",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"deploy": "pnpm run build && wrangler deploy",
		"deploy:dev": "pnpm run build && wrangler deploy --env dev --name reccado-dev",
		"generate:large-mime": "tsx scripts/generate-large-mime.ts",
		"smoke:ws": "tsx scripts/smoke-ws.ts",
		"smoke:email:large": "tsx scripts/smoke-large-email-local.ts",
		"smoke:email:local": "tsx scripts/smoke-email-local.ts",
		"verify:cf": "tsx scripts/verify-cloudflare-bindings.ts",
		"d1:migrate:local": "wrangler d1 migrations apply inbox-mcp-index-dev --local",
		"d1:migrate:dev": "wrangler d1 migrations apply inbox-mcp-index-dev --remote --env dev",
		"seed:dev-id": "tsx scripts/seed-dev-d1.ts",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.26.0",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"hono": "^4.9.6",
		"lucide-react": "^0.545.0",
		"mimetext": "^3.0.28",
		"postal-mime": "^2.7.5",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.1.18",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.20",
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "latest",
		"@tanstack/router-cli": "^1.132.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^28.1.0",
		"tsx": "^4.20.3",
		"typescript": "^6.0.2",
		"vite": "^8.0.0",
		"vitest": "^4.1.5",
		"wrangler": "^4.105.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss",
			"core-js-pure"
		]
	}
}
