# Local-only example values. Do not commit real secrets in `.dev.vars`.
#
# You normally do NOT need to copy this: `pnpm dev` auto-generates a minimal
# `.dev.vars` via scripts/ensure-dev-vars.ts if one is missing. This file is the
# reference for every supported variable.
#
# IMPORTANT: the Cloudflare Access / API-token vars below are commented out on
# purpose. The local-dev bypass in src/lib/runtime-config.ts only kicks in when
# BOTH Access vars are empty/absent, so leaving them set to placeholder values
# would break unauthenticated local `/api/*`. Uncomment them only when you are
# deliberately testing the real Access perimeter or admin provisioning locally.

# --- Local-safe (used by `pnpm dev` and the smoke scripts) ---

# Stable mailbox ID derivation secret for Phase 1.3+.
# Use this exact value locally so dev seed and smokes match (see scripts/seed-dev-d1.ts).
MAILBOX_ID_SECRET=dev-mailbox-id-secret-v1

# Optional Phase 0 debug endpoint token (unlocks /api/debug/phase0/*).
PHASE0_DEBUG_TOKEN=dev-phase0-debug-token

# --- Remote-only (leave commented for local dev; see note above) ---

# Cloudflare API token for admin provisioning workflows.
# Minimum intended scope: zone read, email routing write for test zones, and Access app/policy write only when configuring Access by API.
# CLOUDFLARE_API_TOKEN=replace-with-least-privilege-token

# Cloudflare Access validation settings for protected UI/API.
# ACCESS_JWT_AUDIENCE=replace-with-access-aud-tag
# ACCESS_TEAM_DOMAIN=https://replace-team.cloudflareaccess.com
