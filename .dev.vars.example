# Local-only example values. Do not commit real secrets in `.dev.vars`.
#
# You normally do NOT need to copy this: `pnpm dev` auto-generates a minimal
# `.dev.vars` via scripts/ensure-dev-vars.ts if one is missing. This file is the
# reference for every supported variable AND the canonical basis for `wrangler types`
# (`pnpm cf-typegen`) — so every key must stay present here even when its value is empty,
# or the generated worker-configuration.d.ts would drop it.
#
# The Access / API-token values are intentionally LEFT EMPTY (not placeholder strings):
# the local-dev bypass in src/lib/runtime-config.ts stays active only while BOTH Access
# vars are empty/absent, so copying this file verbatim keeps local `/api/*` working.
# Fill them in only when you deliberately test the real Access perimeter or admin
# provisioning locally.

# Key order below is significant: `wrangler types` emits keys in this order, so it must match
# the committed worker-configuration.d.ts (the CI "generated artifacts" check diffs it).

# Unlocks the local /api/debug/phase0/* introspection endpoints the smoke scripts use.
PHASE0_DEBUG_TOKEN=dev-phase0-debug-token

# Stable mailbox ID derivation secret for Phase 1.3+.
# Use this exact value locally so dev seed and smokes match (see scripts/seed-dev-d1.ts).
MAILBOX_ID_SECRET=dev-mailbox-id-secret-v1

# Cloudflare API token for admin provisioning workflows (leave empty for local dev).
# Minimum intended scope: zone read, email routing write for test zones, and Access app/policy write only when configuring Access by API.
CLOUDFLARE_API_TOKEN=

# Cloudflare Access validation settings (leave empty for local dev; see note above).
ACCESS_JWT_AUDIENCE=
ACCESS_TEAM_DOMAIN=
